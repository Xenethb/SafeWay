<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    tools:context=".HomeActivity">

    <!-- Top banner -->
    <LinearLayout
        android:id="@+id/banner"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#3B8FC1"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvWelcome"
                android:text="Hello User"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:text="Welcome Home."
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_user"
            android:background="@drawable/circle_bg"
            android:scaleType="centerCrop"/>
    </LinearLayout>

    <!-- Search icon -->
    <ImageButton
        android:id="@+id/btnSearch"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_below="@id/banner"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/circle_search"
        android:scaleType="centerInside"
        android:src="@drawable/ic_search"
        app:backgroundTint="@null"
        android:backgroundTint="@null"/>

    <!-- SOS button -->
    <Button
        android:id="@+id/btnSOS"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:layout_below="@id/banner"
        android:background="@drawable/sos_button_bg"
        android:text="SOS"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:elevation="6dp"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:backgroundTint="@null"
        app:backgroundTint="@null"
        />

    <!-- Manage Activation button -->

    <!-- Bottom navigation -->

    <Button
        android:id="@+id/btnManage"
        android:layout_width="160dp"
        android:layout_height="50dp"
        android:layout_below="@id/btnSOS"
        android:layout_alignBottom="@+id/bottomNav"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="61dp"
        android:layout_marginBottom="273dp"
        android:background="@drawable/blue_rounded_btn"
        android:padding="12dp"
        android:text="Manage Activation"
        android:textColor="@color/border_blue"
        app:backgroundTint="@null" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="-6dp"
        android:background="@drawable/nav_gradient"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMap"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="Map"
            android:insetLeft="4dp"
            android:insetTop="4dp"
            android:insetRight="4dp"
            android:insetBottom="4dp"
            android:padding="8dp"
            android:strokeColor="@color/your_border_color"
            android:text=""
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_map"
            app:iconGravity="textStart"
            app:iconSize="50dp"
            app:iconTint="@null"
            app:strokeWidth="2dp" />


        //setting button
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="Settings"
            android:insetLeft="4dp"
            android:insetTop="4dp"
            android:insetRight="4dp"
            android:insetBottom="4dp"
            android:padding="8dp"
            android:strokeColor="@color/your_border_color"
            android:text=""
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconSize="40dp"
            app:iconTint="@null"
            app:strokeWidth="2dp" />


        //friends button
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFriends"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="Friends"
            android:insetLeft="4dp"
            android:insetTop="4dp"
            android:insetRight="4dp"
            android:insetBottom="4dp"
            android:padding="8dp"
            android:strokeColor="@color/your_border_color"
            android:text=""
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_friends"
            app:iconGravity="textStart"
            app:iconSize="45dp"
            app:iconTint="@null"
            app:strokeWidth="2dp" />


        //history logs button
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:contentDescription="History"
            android:insetLeft="4dp"
            android:insetTop="4dp"
            android:insetRight="4dp"
            android:insetBottom="4dp"
            android:padding="1dp"
            android:strokeColor="@color/your_border_color"
            android:text=""
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_history"
            app:iconGravity="textStart"
            app:iconSize="50dp"
            app:iconTint="@null"
            app:strokeWidth="2dp" />
    </LinearLayout>


</RelativeLayout>
