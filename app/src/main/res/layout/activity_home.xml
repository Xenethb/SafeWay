<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    tools:context=".HomeActivity">

    <!-- Top banner -->
    <LinearLayout
        android:id="@+id/banner"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#1C608C"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvWelcome"
                android:text="Hello User"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:text="Welcome Home."
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_user"
            android:background="@drawable/circle_bg"
            android:scaleType="centerCrop"/>
    </LinearLayout>

    <!-- Search icon -->
    <ImageButton
        android:id="@+id/btnSearch"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        android:background="@drawable/circle_search"
        android:scaleType="centerInside"
        android:src="@drawable/ic_search"
        app:layout_constraintTop_toBottomOf="@id/banner"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Monitor Switch -->
    <Switch
        android:id="@+id/switchMonitor"
        android:layout_width="198dp"
        android:layout_height="43dp"
        android:text="Monitor SOS Alerts"
        app:layout_constraintTop_toBottomOf="@id/banner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />


    <!-- SOS Alerts Button -->
    <ImageButton
        android:id="@+id/btnSosAlerts"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/circle_bg"
        android:contentDescription="SOS Alerts"
        android:padding="12dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_alert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/switchMonitor" />

    <Button
        android:id="@+id/btnSOS"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="84dp"
        android:background="@drawable/sos_button_bg"
        android:text="SOS"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/switchMonitor" />

    <!-- Manage Activation button -->
    <Button
        android:id="@+id/btnManage"
        android:layout_width="212dp"
        android:layout_height="63dp"
        android:layout_marginTop="356dp"
        android:background="@drawable/blue_rounded_btn"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp"
        android:text="Manage Activation"
        android:textColor="#002147"
        android:textSize="16sp"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.537"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/switchMonitor" />

    <!-- Bottom navigation (new - equal items, square icons + label) -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:baselineAligned="false"
        android:background="@drawable/nav_gradient"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="-6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Map item (container id kept as btnMap so existing code still finds it) -->
        <LinearLayout
            android:id="@+id/btnMap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <ImageView
                android:id="@+id/icon_map"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_map"
                android:scaleType="centerInside"
                android:background="@drawable/icon_bg_square"
                android:contentDescription="Map"
                app:tint="@color/border_blue"/>

            <TextView
                android:id="@+id/label_map"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Map"
                android:textSize="12sp"
                android:textColor="@color/border_blue"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Settings item -->
        <LinearLayout
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <ImageView
                android:id="@+id/icon_settings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_settings"
                android:scaleType="centerInside"
                android:background="@drawable/icon_bg_square"
                android:contentDescription="Settings"
                app:tint="@color/border_blue" />

            <TextView
                android:id="@+id/label_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="12sp"
                android:textColor="@color/border_blue"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Friends item -->
        <LinearLayout
            android:id="@+id/btnFriends"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <ImageView
                android:id="@+id/icon_friends"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_friends"
                android:scaleType="centerInside"
                android:background="@drawable/icon_bg_square"
                android:contentDescription="Friends"
                app:tint="@color/border_blue" />

            <TextView
                android:id="@+id/label_friends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Friends"
                android:textSize="12sp"
                android:textColor="@color/border_blue"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- History item -->
        <LinearLayout
            android:id="@+id/btnHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp">

            <ImageView
                android:id="@+id/icon_history"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_history"
                android:scaleType="centerInside"
                android:background="@drawable/icon_bg_square"
                android:contentDescription="History"
                app:tint="@color/border_blue" />

            <TextView
                android:id="@+id/label_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textSize="12sp"
                android:textColor="@color/border_blue"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
