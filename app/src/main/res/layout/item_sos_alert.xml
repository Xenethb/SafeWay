<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvAlertName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sender"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvAlertTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20 Aug 12:00"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvAlertName"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvAlertLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="6.9271, 79.8612"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvAlertName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvAlertTime"
        android:gravity="end"/>

</androidx.constraintlayout.widget.ConstraintLayout>

